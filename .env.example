# ============================================================================
# AEGIS — .env.example   (commit THIS file with placeholders; never the real one)
# Copy to .env.local (frontend) and .env (backend). Both are gitignored.
# ============================================================================

# ── FRONTEND (shipped to the browser — these are PUBLIC by design) ──────────
# The anon key is safe to expose ONLY because Row Level Security protects every
# table. If RLS is off on any table, this key is an open door. See SECURITY_REVIEW.md.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── BACKEND ONLY (server env / secret store — NEVER prefix with NEXT_PUBLIC_) ──
# service_role bypasses RLS entirely. Treat it like the database root password.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY            # SECRET — bypasses RLS
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres # SECRET — contains DB password (pooler, port 6543)

# Google Drive — point at the JSON key by PATH; do not inline the key material.
# The file itself is gitignored (service-account*.json).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json   # SECRET FILE
AEGIS_ROOT_FOLDER_ID=YOUR_DRIVE_ROOT_FOLDER_ID                  # identifier, not a secret
DRIVE_POLL_INTERVAL_HOURS=72                                    # cadence, not a secret

# OAuth client ID/secret do NOT belong here — they live in the Supabase dashboard
# (Authentication → Providers → Google). Your code never touches them.

# ── Email (faculty check-ins, notifications) ────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_KEY                                  # SECRET
EMAIL_FROM=aegis@your-domain.lk

# ── Engine tuning (OPTIONAL per-environment overrides) ──────────────────────
# Canonical weights/thresholds live in engine/config.py — these only override.
# Leave unset to use the in-code defaults.
DUPLICATE_GATE_THRESHOLD=0.75
GHOSTING_TIER3_DAYS=10
SYMPATHY_CARRY_RATIO=0.95
