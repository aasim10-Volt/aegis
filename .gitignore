# ── SECRETS: never commit these (public repo = instant compromise + PDPA breach) ──
.env
.env.*
!.env.example
*.local

# Google service-account credentials — the single most dangerous file in this repo.
# It can read/write every team's Drive workspace. NEVER commit.
service-account*.json
*service_account*.json
*service-account*.json
gcp-*.json
credentials.json
client_secret*.json
*.pem
/secrets/
**/secrets/**

# Local tool / agent config — may reference local paths, tokens, or MCP servers
.claude.json
.claude/settings.local.json
.claude.zip
*.zip
.mcp.json

# Supabase / DB
.supabase/
supabase/.temp/
# Database dumps from scripts/backup_db.py — contain ALL live data, never commit.
backups/
*.sql.gz
aegis_*.sql
# Staff directory seed — REAL institutional emails, never commit (use the .example template).
supabase/staff_directory_seed.local.sql
**/*_seed.local.sql

# Demo judge-account seeder — carries throwaway demo passwords; keep out of the public repo.
scripts/seed_demo_users.py
# Demo student mapper — ties a demo account to a REAL cohort student (name/PII); keep local.
scripts/map_demo_student.py

