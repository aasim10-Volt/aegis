  "projects": [
    {
      "project_id": "P_01", "title": "Campus Mental-Health Companion App", "capacity": 4,
      "supervisor_id": "SUP_01", "total_hours": 200.0,
      "required_skills": ["technical", "ux", "communication"],
      "critical_skills": ["technical"], "meeting_slots": ["mon_am", "wed_pm"],
      "abstract": "A mobile wellbeing companion for university students that combines mood journaling, anonymous peer support rooms, and a triage chatbot that escalates high-risk conversations to campus counsellors. The app integrates with the student calendar to suggest breaks during heavy assessment periods and uses on-device sentiment analysis so that sensitive text never leaves the phone. The goal is to reduce the barrier to seeking help by making the first step private, fast, and non-judgemental."
    },
    {
      "project_id": "P_02", "title": "Smart Campus Food-Waste Reduction Platform", "capacity": 5,
      "supervisor_id": "SUP_02", "total_hours": 220.0,
      "required_skills": ["technical", "ux"],
      "critical_skills": ["technical"], "meeting_slots": ["tue_pm", "thu_am"],
      "abstract": "A platform that tackles food waste in campus canteens using computer vision to measure plate waste at the tray-return station and machine learning to forecast daily demand so kitchens cook closer to what is actually eaten. Surplus meals are matched in real time to a student marketplace where discounted portions can be claimed before closing. Dashboards give catering managers waste analytics by dish, day, and hall, turning guesswork into measurable reduction targets."
    },
    {
      "project_id": "P_03", "title": "AI Canteen Surplus and Plate-Waste Analytics", "capacity": 4,
      "supervisor_id": "SUP_03", "total_hours": 210.0,
      "required_skills": ["technical", "ux"],
      "critical_skills": ["technical"], "meeting_slots": ["tue_pm", "thu_am"],
      "abstract": "A system to reduce canteen food waste on campus by applying computer vision at the tray-return point to quantify plate waste and using machine learning to predict daily meal demand so kitchens prepare closer to real consumption. Leftover surplus is offered through a real-time student marketplace where remaining portions are claimed at a discount before service ends. Catering staff get analytics dashboards breaking waste down by dish, day, and dining hall to set and track measurable reduction goals."
    },
    {
      "project_id": "P_04", "title": "Accessible Museum AR Tour Designer", "capacity": 4,
      "supervisor_id": "SUP_04", "total_hours": 200.0,
      "required_skills": ["ux", "technical", "communication"],
      "critical_skills": ["ux"], "meeting_slots": ["mon_am", "thu_pm"],
      "abstract": "An augmented-reality authoring tool that lets museum curators build self-guided tours which adapt to each visitor's accessibility needs, offering audio description for low-vision guests, sign-language avatars for deaf visitors, and simplified-language tracks for neurodivergent audiences. The emphasis is on inclusive interaction design so that a single exhibit can be experienced many ways without curators needing to code. Strong user-experience research drives every layout and navigation decision."
    },
    {
      "project_id": "P_05", "title": "Peer-to-Peer Skill Exchange Network", "capacity": 5,
      "supervisor_id": "SUP_05", "total_hours": 215.0,
      "required_skills": ["technical", "management", "communication"],
      "critical_skills": ["management"], "meeting_slots": ["mon_am", "fri_am"],
      "abstract": "A marketplace where students trade skills rather than money: a coder tutors a designer in algorithms while the designer builds their portfolio site in return. The platform handles scheduling, reputation, and a fair-exchange ledger that keeps trades balanced over time. The hard problem is operations and trust management at scale, making project management and clear communication the load-bearing disciplines for the team that builds it."
    },
    {
      "project_id": "P_06", "title": "Community Disaster-Response Coordination Hub", "capacity": 5,
      "supervisor_id": "SUP_06", "total_hours": 230.0,
      "required_skills": ["management", "communication", "technical"],
      "critical_skills": ["communication"], "meeting_slots": ["tue_am", "fri_pm"],
      "abstract": "A coordination hub for neighbourhood disaster response that maps volunteers, supplies, and shelter capacity during floods and storms, then routes requests to the nearest able responder. It works offline-first over intermittent connectivity and falls back to SMS when data networks fail. Because lives depend on clear instructions under stress, the project leans heavily on communication design and operational management rather than raw engineering novelty."
    },
    {
      "project_id": "P_07", "title": "Open-Source Research Reproducibility Tracker", "capacity": 4,
      "supervisor_id": "SUP_07", "total_hours": 205.0,
      "required_skills": ["technical", "management", "communication"],
      "critical_skills": ["technical"], "meeting_slots": ["tue_pm", "thu_pm"],
      "abstract": "A tool that helps research labs prove their published results can be reproduced by capturing the exact code, data snapshot, and environment behind every figure in a paper and re-running the pipeline on demand. It flags when a dependency drifts or a dataset changes so that silent reproducibility rot is caught early. The target users are academic groups who want a verifiable audit trail from raw data to final chart."
    },
    {
      "project_id": "P_08", "title": "Urban Cycling Safety Heatmap", "capacity": 4,
      "supervisor_id": "SUP_08", "total_hours": 195.0,
      "required_skills": ["technical", "ux"],
      "critical_skills": ["technical"], "meeting_slots": ["wed_am", "fri_pm"],
      "abstract": "A city cycling-safety map that fuses crowdsourced near-miss reports, open accident records, and road-gradient data to highlight dangerous junctions and suggest safer routes for commuters. Riders log incidents with one tap, and councils get an evidence base for where to invest in protected lanes. The design challenge is turning noisy, sparse citizen data into a trustworthy signal that holds up to public scrutiny."
    }
  ],

